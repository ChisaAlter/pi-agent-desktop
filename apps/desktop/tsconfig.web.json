{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "noEmit": true,
    "isolatedModules": true,
    "allowJs": true,
    "skipLibCheck": true,
    "composite": true,
    "tsBuildInfoFile": "./dist/tsconfig.web.tsbuildinfo"
  },
  "include": ["src/renderer/**/*"],
  "exclude": ["node_modules", "dist", "out"]
}