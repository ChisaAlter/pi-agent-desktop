{
  "name": "@pi-desktop/desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Pi Agent Desktop Application",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "package": "electron-builder build --win --config.win.signAndEditExecutable=false --config.win.sign=false",
    "package:dir": "electron-builder build --win --dir --config.win.signAndEditExecutable=false --config.win.sign=false",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx",
    "test": "vitest --run"
  },
  "dependencies": {
    "@earendil-works/pi-coding-agent": "^0.75.5",
    "@pi-desktop/shared-types": "workspace:*",
    "diff2html": "^3.4.0",
    "electron-store": "^8.0.0",
    "node-pty": "^1.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^9.0.0",
    "rehype-highlight": "^7.0.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@electron-toolkit/utils": "^3.0.0",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "autoprefixer": "^10.4.0",
    "electron": "^34.0.0",
    "electron-builder": "^25.0.0",
    "electron-vite": "^2.0.0",
    "eslint": "^9.0.0",
    "postcss": "^8.4.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vitest": "^2.0.0"
  }
}