{
  "name": "@pi-desktop/desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Pi Agent Desktop Application",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "package": "electron-builder build --win --publish never",
    "package:dir": "electron-builder build --win --dir",
    "package:publish": "electron-builder build --win --publish onTagOrRelease",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx",
    "test": "vitest --run",
    "e2e": "playwright test",
    "e2e:build": "electron-vite build && playwright test"
  },
  "dependencies": {
    "@earendil-works/pi-coding-agent": "^0.75.5",
    "@pi-desktop/shared-types": "workspace:*",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "diff2html": "^3.4.0",
    "electron-log": "^5.2.0",
    "electron-store": "^8.0.0",
    "electron-updater": "^6.3.9",
    "i18next": "^26.3.0",
    "i18next-browser-languagedetector": "^8.2.1",
    "node-pty": "^1.1.0",
    "pi-openplan": "^1.3.0",
    "pi-permission-system": "^0.6.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-i18next": "^17.0.8",
    "react-markdown": "^9.0.0",
    "rehype-highlight": "^7.0.0",
    "zod": "^3.23.8",
    "zustand": "^5.0.0"
