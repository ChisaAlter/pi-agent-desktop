{
  "name": "pi-desktop",
  "version": "1.0.12",
  "private": true,
  "description": "Pi Agent Desktop Application - A Windows desktop app for Pi CLI",
  "keywords": [
    "pi",
    "agent",
    "desktop",
    "electron",
    "ai"
  ],
  "license": "MIT",
  "author": "Pi Desktop Contributors",
  "engines": {
    "node": ">=22.19.0"
  },
  "packageManager": "pnpm@9.0.0",
  "pnpm": {
    "overrides": {
      "dmg-builder": "^26.15.0",
      "electron-builder-squirrel-windows": "^26.15.3",
      "esbuild": "^0.28.1",
      "glob": "^10.5.0",
      "tar": "^7.5.10"
    }
  },
  "scripts": {
    "dev": "pnpm -r run dev",
    "build": "pnpm -r run build",
    "lint": "pnpm -r run lint",
    "test": "pnpm -r run test",
    "clean": "pnpm -r run clean",
    "typecheck": "pnpm -r run typecheck",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "@eslint/js": "^9",
    "@playwright/test": "^1.49.0",
    "@typescript-eslint/parser": "^8",
    "eslint-plugin-react-hooks": "^5",
    "lefthook": "^2.1.9",
    "playwright": "^1.49.0",
    "typescript-eslint": "^8"
  }
}
